{
  "platform": { "apiRuntime": null },
  "routes": [
    { "route": "/data/*", "headers": { "cache-control": "public, max-age=60" } },
    { "route": "/sample/*", "headers": { "cache-control": "public, max-age=60" } },

    { "route": "/en", "redirect": "/", "statusCode": 301 },
    { "route": "/en/*", "redirect": "/", "statusCode": 301 },

    { "route": "/competitions/world_cup_2026", "redirect": "/", "statusCode": 301 },
    { "route": "/competitions/world_cup_2026/*", "redirect": "/", "statusCode": 301 },
    { "route": "/competitions/champions_league", "redirect": "/", "statusCode": 301 },
    { "route": "/competitions/champions_league/*", "redirect": "/", "statusCode": 301 },
    { "route": "/competitions/premier_league", "redirect": "/", "statusCode": 301 },
    { "route": "/competitions/premier_league/*", "redirect": "/match/", "statusCode": 301 },
    { "route": "/competitions", "redirect": "/", "statusCode": 301 },
    { "route": "/tournament-simulator", "redirect": "/", "statusCode": 301 },
    { "route": "/tournament-simulator/*", "redirect": "/", "statusCode": 301 },

    { "route": "/match-predictor", "redirect": "/", "statusCode": 301 },
    { "route": "/match-predictor/*", "redirect": "/", "statusCode": 301 },
    { "route": "/teams", "redirect": "/", "statusCode": 301 },
    { "route": "/teams/*", "redirect": "/", "statusCode": 301 },
    { "route": "/this-week-matches", "redirect": "/", "statusCode": 301 },
    { "route": "/this-week-matches/*", "redirect": "/", "statusCode": 301 },

    { "route": "/model-diagnostics", "redirect": "/about/", "statusCode": 301 },
    { "route": "/model-diagnostics/*", "redirect": "/about/", "statusCode": 301 },
    { "route": "/data-quality", "redirect": "/about/", "statusCode": 301 },
    { "route": "/data-quality/*", "redirect": "/about/", "statusCode": 301 },
    { "route": "/source-code", "redirect": "/about/", "statusCode": 301 },
    { "route": "/source-code/*", "redirect": "/about/", "statusCode": 301 }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/data/*", "/sample/*", "/_next/*", "/icons/*"]
  },
  "globalHeaders": {
    "x-content-type-options": "nosniff",
    "x-frame-options": "DENY",
    "referrer-policy": "strict-origin-when-cross-origin",
    "permissions-policy": "camera=(), microphone=(), geolocation=()"
  }
}
